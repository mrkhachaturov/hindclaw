{
  "name": "@hindclaw/client",
  "version": "0.1.0",
  "description": "TypeScript client for Hindclaw access control API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "clean": "rm -rf dist",
    "generate": "npx @hey-api/openapi-ts",
    "test": "jest",
    "test:deno": "deno test --no-check --allow-env --allow-net --unstable-sloppy-imports --preload=tests/deno_setup.ts tests/smoke.test.ts"
  },
  "author": "Hindclaw",
  "license": "MIT",
  "dependencies": {
    "@vectorize-io/hindsight-client": "0.5.1"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.88.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.12.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "src",
    "generated",
    "README.md"
  ]
}
